# Formulierbezorging (vereist om inzendingen te accepteren)
# Maak website@sitora.nl eerst als geverifieerde afzender aan in Resend.
RESEND_API_KEY=
LEAD_TO_EMAIL=info@sitora.nl
LEAD_FROM_EMAIL="Sitora website <website@sitora.nl>"

# Optionele meting — scripts laden pas na toestemming én configuratie
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
